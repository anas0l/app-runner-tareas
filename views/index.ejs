<!DOCTYPE html>
<html lang="es">
<head>
 <meta charset="UTF-8">
 <title>Lista de tareas</title>
 <style>
 body {
   font-family: Arial, sans-serif;
   margin: 40px;
   max-width: 800px;
 }
 h1 {
   color: #1f3c88;
 }
 form {
   margin-bottom: 20px;
 }
 input[type="text"] {
   padding: 8px;
   width: 300px;
 }
 button {
   padding: 8px 12px;
   background: #1f3c88;
   color: white;
   border: none;
   cursor: pointer;
 }
 li {
   margin-bottom: 8px;
 }
 </style>
</head>
<body>
 <h1>Lista de tareas</h1>
 <form action="/nueva" method="POST">
 <input type="text" name="texto" placeholder="Escribe una tarea" required>
 <button type="submit">Guardar</button>
 </form>
 <ul>
 <% tareas.forEach(tarea => { %>
 <li><%= tarea.texto %></li>
 <% }) %>
 </ul>
</body>
</html>
